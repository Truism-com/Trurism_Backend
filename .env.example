# Example environment variables for Travel Booking Platform

# Database
# Local development example (Postgres)
DATABASE_URL=postgresql+asyncpg://travel_user:dev_password@localhost:5432/travel_booking_dev

# Redis (used for caching and token blacklist)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change_me_to_a_strong_secret_in_prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
DEBUG=true
ENVIRONMENT=development

# External APIs / services (placeholders)
XML_AGENCY_USERNAME=
XML_AGENCY_PASSWORD=

# Celery (broker) - using Redis here for development
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
