# ============================================
# TRAVEL BOOKING PLATFORM - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in the values

# --------------------------------------------
# APPLICATION SETTINGS
# --------------------------------------------
APP_NAME=Travel Booking Platform
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false
SKIP_DB_INIT=false

# --------------------------------------------
# DATABASE CONFIGURATION
# --------------------------------------------
# Supports: Azure PostgreSQL, Supabase, or local PostgreSQL
#
# === Azure Database for PostgreSQL (Recommended for Azure deployment) ===
# Format: postgresql+asyncpg://USER:PASSWORD@SERVER.postgres.database.azure.com:5432/DBNAME?ssl=require
# Example: postgresql+asyncpg://trurismadmin:MyPass123@trurism-db.postgres.database.azure.com:5432/trurism?ssl=require
#
# === Supabase (Alternative) ===
# Format: postgresql+asyncpg://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
#
# === Local PostgreSQL (Development) ===
# Format: postgresql+asyncpg://postgres:password@localhost:5432/trurism
#
# NOTE: If your password contains special characters, URL-encode them:
#   @ = %40, # = %23, $ = %24

# Database connection for async operations (application runtime)
DATABASE_URL=postgresql+asyncpg://verifyadmin:Trurism%402026@trurism-db-verify-sea.postgres.database.azure.com:5432/postgres

# Database connection for migrations (synchronous - uses psycopg)
DATABASE_MIGRATION_URL=postgresql+psycopg://trurismadmin:YOUR_PASSWORD@trurism-db.postgres.database.azure.com:5432/trurism?sslmode=require

# Connection pool settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --------------------------------------------
# REDIS CACHE CONFIGURATION
# --------------------------------------------
# Options:
# 1. Local Redis: redis://localhost:6379
# 2. Upstash (free tier): redis://default:password@your-redis.upstash.io:6379
# 3. Redis Cloud: redis://default:password@your-redis.redislabs.com:6379
# 4. Disable Redis: none
REDIS_URL=none
REDIS_DB=0
SEARCH_CACHE_TTL=900
SESSION_CACHE_TTL=3600

# --------------------------------------------
# JWT AUTHENTICATION
# --------------------------------------------
# ⚠️ IMPORTANT: Generate a strong secret for production:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=4f8e02d4b9c1a5e3f7d2b8c4a0e1d9f3b5c7a9d2e4f6b8c0a1d3e5f7b9c1d3e5
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# --------------------------------------------
# SECURITY SETTINGS
# --------------------------------------------
BCRYPT_ROUNDS=12
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# --------------------------------------------
# CELERY / BACKGROUND TASKS
# --------------------------------------------
# Requires Redis - set REDIS_URL first
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --------------------------------------------
# EXTERNAL API: XML.AGENCY (FLIGHT SEARCH & BOOKING)
# --------------------------------------------
# Sign up at: https://xml.agency/
# Documentation: Request from xml.agency support
XML_AGENCY_BASE_URL=https://test-api.xml.agency
XML_AGENCY_USERNAME=your_xml_agency_username
XML_AGENCY_PASSWORD=your_xml_agency_password
XML_AGENCY_TIMEOUT=30

# --------------------------------------------
# FLIGHT API (Alternative to XML.Agency)
# --------------------------------------------
# Supports: Amadeus, Travelport, XML.Agency, etc.
FLIGHT_API_URL=https://api.flight-supplier.com
FLIGHT_API_KEY=your_flight_api_key
FLIGHT_API_SECRET=your_flight_api_secret

# --------------------------------------------
# BUS API CONFIGURATION
# --------------------------------------------
# Supports: RedBus API, AbhiBus, VRL Travels, etc.
BUS_API_URL=https://api.bus-supplier.com
BUS_API_KEY=your_bus_api_key
BUS_API_SECRET=your_bus_api_secret

# --------------------------------------------
# HOTEL API CONFIGURATION
# --------------------------------------------
# Supports: Booking.com, Expedia, Agoda APIs, etc.
HOTEL_API_URL=https://api.hotel-supplier.com
HOTEL_API_KEY=your_hotel_api_key
HOTEL_API_SECRET=your_hotel_api_secret

# --------------------------------------------
# PAYMENT GATEWAY: RAZORPAY
# --------------------------------------------
# ⚠️ REQUIRED FOR PAYMENT PROCESSING
# Sign up at: https://razorpay.com/
# Dashboard: https://dashboard.razorpay.com/#/app/keys
#
# Steps:
# 1. Login to Razorpay Dashboard
# 2. Go to: Settings → API Keys
# 3. Generate API Keys (Test for development, Live for production)
# 4. Copy Key ID and Key Secret
#
# Test Keys: Start with "rzp_test_"
# Live Keys: Start with "rzp_live_"
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# Webhook Secret - Generate when setting up webhook
# Dashboard: Settings → Webhooks → Create Webhook
# URL: https://yourdomain.com/payments/webhook
# Events: payment.captured, payment.failed, order.paid, refund.processed
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# --------------------------------------------
# EMAIL CONFIGURATION
# --------------------------------------------
# For Gmail:
# 1. Enable 2-Factor Authentication: myaccount.google.com/security
# 2. Generate App Password: myaccount.google.com/apppasswords
# 3. Select "Mail" and "Windows Computer" (or Other)
# 4. Copy the 16-character password
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_FROM=your-email@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_USE_TLS=true

# --------------------------------------------
# FILE UPLOAD SETTINGS
# --------------------------------------------
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=.jpg,.jpeg,.png,.pdf

# --------------------------------------------
# OPTIONAL: MONITORING & LOGGING
# --------------------------------------------
LOG_LEVEL=INFO
# SENTRY_DSN=https://your-sentry-dsn-here

# --------------------------------------------
# AZURE APP SERVICE / APPLICATION INSIGHTS
# --------------------------------------------
APPINSIGHTS_INSTRUMENTATIONKEY=62d87a8c-f701-485e-b27b-76600f22d842
APPINSIGHTS_PROFILERFEATURE_VERSION=1.0.0
APPINSIGHTS_SNAPSHOTFEATURE_VERSION=1.0.0
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=62d87a8c-f701-485e-b27b-76600f22d842;IngestionEndpoint=https://southeastasia-1.in.applicationinsights.azure.com/;LiveEndpoint=https://southeastasia.livediagnostics.monitor.azure.com/;ApplicationId=2bd35aaf-e731-4951-a330-9754c598615d
ApplicationInsightsAgent_EXTENSION_VERSION=~3
CORS_ORIGINS=https://trurism-api.azurewebsites.net,http://localhost:3000
DiagnosticServices_EXTENSION_VERSION=~3
InstrumentationEngine_EXTENSION_VERSION=disabled
RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET
RAZORPAY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET
SCM_DO_BUILD_DURING_DEPLOYMENT=true
SnapshotDebugger_EXTENSION_VERSION=disabled
TRUSTED_HOSTS=trurism-api.azurewebsites.net,localhost
WEBSITE_HTTPLOGGING_RETENTION_DAYS=3
WEBSITES_PORT=8000
XDT_MicrosoftApplicationInsights_BaseExtensions=disabled
XDT_MicrosoftApplicationInsights_Mode=recommended
XDT_MicrosoftApplicationInsights_PreemptSdk=disabled
