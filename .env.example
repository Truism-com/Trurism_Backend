# ============================================
# TRAVEL BOOKING PLATFORM - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values
# ============================================

# --------------------------------------------
# APPLICATION SETTINGS
# --------------------------------------------
APP_NAME=Travel Booking Platform
APP_VERSION=1.0.0
ENVIRONMENT=development  # development, staging, or production
DEBUG=true  # Set to false in production

# --------------------------------------------
# DATABASE CONFIGURATION
# --------------------------------------------
# PostgreSQL connection string
# Format: postgresql+asyncpg://username:password@host:port/database
DATABASE_URL=postgresql+asyncpg://trurism_user:tru_user2025@localhost:5432/trurism_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --------------------------------------------
# REDIS CACHE CONFIGURATION
# --------------------------------------------
# Redis connection string for caching and session management
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# Cache TTL settings (in seconds)
SEARCH_CACHE_TTL=900  # 15 minutes
SESSION_CACHE_TTL=3600  # 1 hour

# --------------------------------------------
# JWT AUTHENTICATION
# --------------------------------------------
# Generate a strong secret key using: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-to-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --------------------------------------------
# SECURITY SETTINGS
# --------------------------------------------
BCRYPT_ROUNDS=12
RATE_LIMIT_PER_MINUTE=60

# --------------------------------------------
# CELERY / BACKGROUND TASKS
# --------------------------------------------
# For background job processing (notifications, reports, etc.)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --------------------------------------------
# EXTERNAL API: XML.AGENCY (FLIGHT SEARCH & BOOKING)
# --------------------------------------------
# Sign up at: https://xml.agency/
# Documentation: Check your XML Agency Flight API.pdf
XML_AGENCY_BASE_URL=https://test-api.xml.agency  # Use https://api.xml.agency for production
XML_AGENCY_USERNAME=
XML_AGENCY_PASSWORD=
XML_AGENCY_TIMEOUT=30

# --------------------------------------------
# PAYMENT GATEWAY: RAZORPAY
# --------------------------------------------
# Sign up at: https://razorpay.com/
# Get keys from: https://dashboard.razorpay.com/#/app/keys
RAZORPAY_KEY_ID=  # Format: rzp_test_xxxxx (test) or rzp_live_xxxxx (production)
RAZORPAY_KEY_SECRET=  # Keep this secret!

# Webhook configuration (for payment confirmations)
RAZORPAY_WEBHOOK_SECRET=  # Get from Razorpay Dashboard -> Webhooks

# --------------------------------------------
# EMAIL CONFIGURATION
# --------------------------------------------
# For sending booking confirmations, password resets, etc.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_FROM=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password  # Gmail: Use App Password, not regular password
MAIL_USE_TLS=true

# --------------------------------------------
# FILE UPLOAD SETTINGS
# --------------------------------------------
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=.jpg,.jpeg,.png,.pdf

# --------------------------------------------
# MONITORING & LOGGING (OPTIONAL)
# --------------------------------------------
# Sentry for error tracking
SENTRY_DSN=

# Application Insights (Azure)
APPINSIGHTS_INSTRUMENTATION_KEY=

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --------------------------------------------
# PRODUCTION-SPECIFIC SETTINGS
# --------------------------------------------
# Only needed when ENVIRONMENT=production

# CORS allowed origins (comma-separated)
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Trusted hosts (comma-separated)
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# SSL/HTTPS settings
# FORCE_HTTPS=true

# --------------------------------------------
# THIRD-PARTY INTEGRATIONS (FUTURE)
# --------------------------------------------
# Hotel Search API (e.g., Booking.com, Expedia, etc.)
# HOTEL_API_KEY=
# HOTEL_API_SECRET=

# Bus Booking API (e.g., RedBus API)
# BUS_API_KEY=
# BUS_API_SECRET=

# SMS Gateway (for OTP, notifications)
# SMS_API_KEY=
# SMS_SENDER_ID=

# WhatsApp Business API
# WHATSAPP_API_KEY=
# WHATSAPP_PHONE_NUMBER=
